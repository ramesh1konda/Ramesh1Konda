{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile with role-based access.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["borrower", "lender", "admin", "broker"], "description": "The user's role in the system." },
        "createdAt": { "type": "string", "format": "date-time" },
        "notificationPreferences": {
          "type": "object",
          "properties": {
            "emailFrequency": { "type": "string", "enum": ["instant", "daily", "weekly", "none"] },
            "applicationUpdates": { "type": "boolean" },
            "newProposals": { "type": "boolean" },
            "marketingEmails": { "type": "boolean" }
          }
        },
        "permissions": {
          "type": "object",
          "properties": {
            "canApproveLoans": { "type": "boolean" },
            "canViewAllApplications": { "type": "boolean" },
            "canManageUsers": { "type": "boolean" },
            "canEditApplications": { "type": "boolean" }
          }
        }
      },
      "required": ["uid", "email", "role"]
    },
    "LoanApplication": {
      "title": "Loan Application",
      "description": "A loan application submitted by a borrower.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "borrowerId": { "type": "string", "description": "UID of the borrower." },
        "borrowerName": { "type": "string" },
        "amount": { "type": "number", "description": "Requested loan amount." },
        "purpose": { "type": "string", "description": "Purpose of the loan." },
        "status": { "type": "string", "enum": ["pending", "reviewing", "approved", "rejected", "proposed"], "default": "pending" },
        "brokerId": { "type": "string", "description": "UID of the broker who submitted the application." },
        "brokerEmail": { "type": "string", "format": "email" },
        "creditScore": { "type": "number", "description": "Estimated credit score." },
        "annualIncome": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "lenderNotes": { "type": "string" },
        "documents": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "url": { "type": "string", "format": "uri" },
              "uploadedAt": { "type": "string", "format": "date-time" }
            }
          }
        }
      },
      "required": ["borrowerId", "amount", "purpose", "status"]
    },
    "WhiteLabelConfig": {
      "title": "White Label Configuration",
      "description": "Custom branding settings for a broker.",
      "type": "object",
      "properties": {
        "brokerId": { "type": "string" },
        "companyName": { "type": "string" },
        "logoUrl": { "type": "string", "format": "uri" },
        "primaryColor": { "type": "string", "description": "Hex color code." },
        "welcomeMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["brokerId", "companyName", "primaryColor"]
    },
    "UserInvite": {
      "title": "User Invitation",
      "description": "A pre-authorized invitation for a user to join with a specific role.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["borrower", "lender", "admin", "broker"] },
        "invitedBy": { "type": "string", "description": "UID of the admin who invited the user." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "invitedBy", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/applications/{applicationId}": {
      "schema": "LoanApplication",
      "description": "Loan applications."
    },
    "/brokerConfigs/{brokerId}": {
      "schema": "WhiteLabelConfig",
      "description": "White label configurations for brokers."
    },
    "/userInvites/{inviteId}": {
      "schema": "UserInvite",
      "description": "Pre-authorized user invitations."
    }
  }
}
